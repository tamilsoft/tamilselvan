# =============================================================================
# Clean URLs
#
# Every internal link on the site is extensionless — href="projects",
# href="work-karnataka-eprocurement" — while the files on disk carry .html.
# Without this file those links 404. This maps the request back to the file.
#
# MultiViews would also do it, but it is off by default on many hosts and
# silently guesses at near-matches. An explicit rewrite is predictable.
# =============================================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve foo.html when foo is requested and that file exists.
    # The -d guard lets real directories through untouched.
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.html -f
    RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# -----------------------------------------------------------------------------
# Error page
# Path is absolute from the domain root, so this is correct once deployed to
# tamilsoft.com or similar. Running from a subfolder (XAMPP: /WEBSITE/) it will
# not resolve — harmless locally, and Apache falls back to its own 404.
# -----------------------------------------------------------------------------
ErrorDocument 404 /404.html

# -----------------------------------------------------------------------------
# Caching. The HTML is regenerated by build.php, so it must not be held long;
# the fingerprint-free assets are versioned by hand, so a week is the safe
# ceiling — long enough to help repeat visits, short enough that a CSS change
# reaches people without a hard refresh.
# -----------------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html                 "access plus 0 seconds"
    ExpiresByType text/css                  "access plus 7 days"
    ExpiresByType application/javascript    "access plus 7 days"
    ExpiresByType image/jpeg                "access plus 30 days"
    ExpiresByType image/png                 "access plus 30 days"
    ExpiresByType image/svg+xml             "access plus 30 days"
    ExpiresByType image/webp                "access plus 30 days"
    ExpiresByType font/woff2                "access plus 1 year"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>

# -----------------------------------------------------------------------------
# Keep the build source out of the browser. It contains every project's content
# and the page templates; nothing needs to fetch it over HTTP.
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteRule ^php-src/ - [F,L]
</IfModule>
